rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function userExists(uid) {
      return signedIn() && exists(/databases/$(database)/documents/users/$(uid));
    }

    function docRole() {
      return userExists(request.auth.uid) ? userDoc(request.auth.uid).data.role : null;
    }

    function tokenRole() {
      return signedIn() && request.auth.token.role is string
        ? request.auth.token.role
        : null;
    }

    function tokenIsActive() {
      return signedIn() && request.auth.token.is_active != false;
    }

    function tokenRoleMatches(expectedRole) {
      return tokenIsActive() && tokenRole() == expectedRole;
    }

    function roleMatches(expectedRole) {
      return signedIn()
        && (
          tokenRoleMatches(expectedRole)
          || (
            userExists(request.auth.uid)
            && userDoc(request.auth.uid).data.is_active != false
            && docRole() == expectedRole
          )
        );
    }

    function isAdmin() {
      return roleMatches('admin');
    }

    function isDoctor() {
      return roleMatches('dokter');
    }

    function isPatient() {
      return roleMatches('pasien');
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).changedKeys();
    }

    function scheduleDoc(scheduleId) {
      return get(/databases/$(database)/documents/schedules/$(scheduleId));
    }

    function queueDoc(queueId) {
      return get(/databases/$(database)/documents/queues/$(queueId));
    }

    function queueDocAfter(queueId) {
      return getAfter(/databases/$(database)/documents/queues/$(queueId));
    }

    function scheduleDocAfter(scheduleId) {
      return getAfter(/databases/$(database)/documents/schedules/$(scheduleId));
    }

    function doctorOwnsSchedule(scheduleId) {
      return exists(/databases/$(database)/documents/schedules/$(scheduleId))
        && scheduleDoc(scheduleId).data.doctor_id == request.auth.uid
        && scheduleDoc(scheduleId).data.is_active == true;
    }

    function queueScheduleMatchesDoctor() {
      return exists(/databases/$(database)/documents/schedules/$(request.resource.data.schedule_id))
        && scheduleDoc(request.resource.data.schedule_id).data.doctor_id == request.resource.data.doctor_id
        && scheduleDoc(request.resource.data.schedule_id).data.is_active == true;
    }

    function queueScheduleMatchesBooking() {
      return queueScheduleMatchesDoctor()
        && request.resource.data.appointment_date == scheduleDoc(request.resource.data.schedule_id).data.date
        && request.resource.data.appointment_time ==
          (scheduleDoc(request.resource.data.schedule_id).data.start_time + ' - ' + scheduleDoc(request.resource.data.schedule_id).data.end_time)
        && request.resource.data.doctor_name == scheduleDoc(request.resource.data.schedule_id).data.doctor_name
        && request.resource.data.doctor_specialization == scheduleDoc(request.resource.data.schedule_id).data.doctor_specialization;
    }

    function scheduleDoctorUpdateAllowed() {
      return changedKeys().hasOnly([
        'current_patients',
        'updated_at',
      ]);
    }

    function patientScheduleIncrementAllowed(scheduleId) {
      let lockId = request.auth.uid + '_' + resource.data.doctor_id;
      return changedKeys().hasOnly([
        'current_patients',
        'updated_at',
      ])
        && request.resource.data.current_patients is int
        && request.resource.data.current_patients == resource.data.current_patients + 1
        && request.resource.data.current_patients <= resource.data.max_patients
        && existsAfter(/databases/$(database)/documents/patient_queue_locks/$(lockId))
        && patientQueueLockDocAfter(lockId).data.patient_id == request.auth.uid
        && patientQueueLockDocAfter(lockId).data.doctor_id == resource.data.doctor_id
        && patientQueueLockDocAfter(lockId).data.schedule_id == scheduleId
        && patientQueueLockDocAfter(lockId).data.status == 'active'
        && existsAfter(/databases/$(database)/documents/queues/$(patientQueueLockDocAfter(lockId).data.queue_id))
        && queueDocAfter(patientQueueLockDocAfter(lockId).data.queue_id).data.patient_id == request.auth.uid
        && queueDocAfter(patientQueueLockDocAfter(lockId).data.queue_id).data.doctor_id == resource.data.doctor_id
        && queueDocAfter(patientQueueLockDocAfter(lockId).data.queue_id).data.status in ['menunggu', 'rescheduled'];
    }

    function patientScheduleDecrementAllowed(scheduleId) {
      let lockId = request.auth.uid + '_' + resource.data.doctor_id;
      return changedKeys().hasOnly([
        'current_patients',
        'updated_at',
      ])
        && request.resource.data.current_patients is int
        && request.resource.data.current_patients == resource.data.current_patients - 1
        && request.resource.data.current_patients >= 0
        && exists(/databases/$(database)/documents/patient_queue_locks/$(lockId))
        && patientQueueLockDoc(lockId).data.patient_id == request.auth.uid
        && patientQueueLockDoc(lockId).data.doctor_id == resource.data.doctor_id
        && patientQueueLockDoc(lockId).data.status == 'active'
        && existsAfter(/databases/$(database)/documents/queues/$(patientQueueLockDoc(lockId).data.queue_id))
        && queueDocAfter(patientQueueLockDoc(lockId).data.queue_id).data.patient_id == request.auth.uid
        && queueDocAfter(patientQueueLockDoc(lockId).data.queue_id).data.doctor_id == resource.data.doctor_id
        && (
          queueDocAfter(patientQueueLockDoc(lockId).data.queue_id).data.status == 'cancelled_by_patient'
          || (
            queueDocAfter(patientQueueLockDoc(lockId).data.queue_id).data.status == 'rescheduled'
            && queueDocAfter(patientQueueLockDoc(lockId).data.queue_id).data.rescheduled_from.schedule_id == scheduleId
          )
        );
    }

    function queuePatientCancelAllowed() {
      return resource.data.status in ['menunggu', 'waiting', 'dipanggil', 'ongoing', 'rescheduled']
        && changedKeys().hasOnly([
          'status',
          'cancelled_at',
          'updated_at',
        ])
        && request.resource.data.status == 'cancelled_by_patient'
        && request.resource.data.updated_at == request.time;
    }

    function queuePatientRescheduleAllowed() {
      return resource.data.status in ['menunggu', 'waiting', 'cancelled_by_doctor']
        && changedKeys().hasOnly([
          'schedule_id',
          'appointment_date',
          'appointment_time',
          'queue_number',
          'status',
          'rescheduled_from',
          'rescheduled_at',
          'cancellation_reason',
          'updated_at',
        ])
        && request.resource.data.status == 'rescheduled'
        && request.resource.data.patient_id == resource.data.patient_id
        && request.resource.data.doctor_id == resource.data.doctor_id
        && request.resource.data.queue_number is int
        && request.resource.data.queue_number > 0
        && request.resource.data.updated_at == request.time
        && queueScheduleMatchesBooking();
    }

    function queueDoctorCallAllowed() {
      return resource.data.status in ['menunggu', 'waiting', 'rescheduled']
        && changedKeys().hasOnly([
          'status',
          'called_at',
          'updated_at',
        ])
        && request.resource.data.status == 'dipanggil';
    }

    function queueDoctorCompleteAllowed() {
      return resource.data.status == 'dipanggil'
        && changedKeys().hasOnly([
          'status',
          'completed_at',
          'updated_at',
        ])
        && request.resource.data.status == 'selesai';
    }

    function queueDoctorSkipAllowed() {
      return resource.data.status == 'dipanggil'
        && changedKeys().hasOnly([
          'status',
          'skipped_at',
          'queue_number',
          'updated_at',
        ])
        && request.resource.data.status == 'menunggu';
    }

    function queueDoctorCancelAllowed() {
      return resource.data.status in ['menunggu', 'waiting', 'dipanggil', 'ongoing', 'rescheduled']
        && changedKeys().hasOnly([
          'status',
          'cancellation_reason',
          'cancelled_at',
          'updated_at',
        ])
        && request.resource.data.status == 'cancelled_by_doctor';
    }

    function doctorNotificationReadOnlyUpdate() {
      return changedKeys().hasOnly(['is_read'])
        && request.resource.data.is_read == true;
    }

    function patientNotificationReadOnlyUpdate() {
      return changedKeys().hasOnly(['is_read'])
        && request.resource.data.is_read == true;
    }

    function queueBelongsToDoctorAndPatient(queueId) {
      return exists(/databases/$(database)/documents/queues/$(queueId))
        && queueDoc(queueId).data.doctor_id == request.resource.data.doctor_id
        && queueDoc(queueId).data.patient_id == request.resource.data.patient_id
        && queueDoc(queueId).data.schedule_id == request.resource.data.schedule_id
        && queueDoc(queueId).data.doctor_id == request.auth.uid;
    }

    function scheduleChangeLockDoc(lockId) {
      return get(/databases/$(database)/documents/schedule_change_request_locks/$(lockId));
    }

    function scheduleChangeLockDocAfter(lockId) {
      return getAfter(/databases/$(database)/documents/schedule_change_request_locks/$(lockId));
    }

    function patientQueueLockDoc(lockId) {
      return get(/databases/$(database)/documents/patient_queue_locks/$(lockId));
    }

    function patientQueueLockDocAfter(lockId) {
      return getAfter(/databases/$(database)/documents/patient_queue_locks/$(lockId));
    }

    function patientQueueLockId(scheduleId) {
      return request.auth.uid + '_' + scheduleDoc(scheduleId).data.doctor_id;
    }

    function queueSequenceCounterDoc(scheduleId) {
      return get(/databases/$(database)/documents/queue_sequence_counters/$(scheduleId));
    }

    function queueSequenceCounterDocAfter(scheduleId) {
      return getAfter(/databases/$(database)/documents/queue_sequence_counters/$(scheduleId));
    }

    function queueMutationMatchesPatientLock(queueId, patientId, doctorId, scheduleId) {
      return existsAfter(/databases/$(database)/documents/queues/$(queueId))
        && queueDocAfter(queueId).data.patient_id == patientId
        && queueDocAfter(queueId).data.doctor_id == doctorId
        && queueDocAfter(queueId).data.schedule_id == scheduleId
        && queueDocAfter(queueId).data.updated_at == request.time;
    }

    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);

      allow create: if isAdmin()
        || (isOwner(userId)
          && request.resource.data.role == 'pasien'
          && request.resource.data.email is string
          && request.resource.data.name is string
          && request.resource.data.phone is string);

      allow update: if isAdmin()
        || (isOwner(userId)
          && request.resource.data.role == resource.data.role
          && changedKeys().hasOnly(['name', 'phone', 'updated_at']));

      allow delete: if isAdmin();
    }

    match /doctors/{doctorId} {
      allow read: if signedIn()
        && (isAdmin()
          || resource.data.user_id == request.auth.uid);

      allow create, update, delete: if isAdmin();
    }

    match /doctors_public/{doctorId} {
      allow read: if signedIn()
        && (isAdmin() || resource.data.is_active == true);

      allow create, update, delete: if isAdmin();
    }

    match /schedules/{scheduleId} {
      allow read: if signedIn()
        && (isAdmin()
          || resource.data.is_active == true
          || resource.data.doctor_id == request.auth.uid);

      allow create, delete: if isAdmin();

      allow update: if isAdmin()
        || (isDoctor()
          && resource.data.doctor_id == request.auth.uid
          && scheduleDoctorUpdateAllowed())
        || (isPatient()
          && (patientScheduleIncrementAllowed(scheduleId)
            || patientScheduleDecrementAllowed(scheduleId)));
    }

    match /queues/{queueId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && (
          isAdmin()
          || (isPatient()
            && request.resource.data.patient_id == request.auth.uid
            && request.resource.data.status == 'menunggu'
            && request.resource.data.doctor_id is string
            && request.resource.data.schedule_id is string
            && request.resource.data.patient_name is string
            && request.resource.data.doctor_name is string
            && request.resource.data.doctor_specialization is string
            && request.resource.data.appointment_date is timestamp
            && request.resource.data.appointment_time is string
            && request.resource.data.queue_number is int
            && request.resource.data.queue_number > 0
            && request.resource.data.complaint is string
            && queueScheduleMatchesBooking()
            && existsAfter(/databases/$(database)/documents/patient_queue_locks/$(request.resource.data.patient_id + '_' + request.resource.data.doctor_id))
            && patientQueueLockDocAfter(request.resource.data.patient_id + '_' + request.resource.data.doctor_id).data.patient_id == request.resource.data.patient_id
            && patientQueueLockDocAfter(request.resource.data.patient_id + '_' + request.resource.data.doctor_id).data.doctor_id == request.resource.data.doctor_id
            && patientQueueLockDocAfter(request.resource.data.patient_id + '_' + request.resource.data.doctor_id).data.schedule_id == request.resource.data.schedule_id
            && patientQueueLockDocAfter(request.resource.data.patient_id + '_' + request.resource.data.doctor_id).data.appointment_date == request.resource.data.appointment_date
            && patientQueueLockDocAfter(request.resource.data.patient_id + '_' + request.resource.data.doctor_id).data.queue_id == queueId
            && (
              (
                !exists(/databases/$(database)/documents/queue_sequence_counters/$(request.resource.data.schedule_id))
                && request.resource.data.queue_number == 1
              )
              || (
                exists(/databases/$(database)/documents/queue_sequence_counters/$(request.resource.data.schedule_id))
                && (
                  (
                    queueSequenceCounterDoc(request.resource.data.schedule_id).data.appointment_date == request.resource.data.appointment_date
                    && queueSequenceCounterDoc(request.resource.data.schedule_id).data.next_queue_number == request.resource.data.queue_number
                  )
                  || (
                    queueSequenceCounterDoc(request.resource.data.schedule_id).data.appointment_date != request.resource.data.appointment_date
                    && request.resource.data.queue_number == 1
                  )
                )
              )
            )
            && existsAfter(/databases/$(database)/documents/queue_sequence_counters/$(request.resource.data.schedule_id))
            && queueSequenceCounterDocAfter(request.resource.data.schedule_id).data.schedule_id == request.resource.data.schedule_id
            && queueSequenceCounterDocAfter(request.resource.data.schedule_id).data.appointment_date == request.resource.data.appointment_date
            && queueSequenceCounterDocAfter(request.resource.data.schedule_id).data.next_queue_number == request.resource.data.queue_number + 1
          )
        );

      allow update: if isAdmin()
        || (resource.data.patient_id == request.auth.uid
          && (queuePatientCancelAllowed() || queuePatientRescheduleAllowed())
          && exists(/databases/$(database)/documents/patient_queue_locks/$(resource.data.patient_id + '_' + resource.data.doctor_id))
          && patientQueueLockDoc(resource.data.patient_id + '_' + resource.data.doctor_id).data.patient_id == resource.data.patient_id
          && patientQueueLockDoc(resource.data.patient_id + '_' + resource.data.doctor_id).data.doctor_id == resource.data.doctor_id)
        || (resource.data.doctor_id == request.auth.uid
          && (queueDoctorCallAllowed() || queueDoctorCompleteAllowed() || queueDoctorSkipAllowed() || queueDoctorCancelAllowed()));

      allow delete: if isAdmin();
    }

    match /schedule_change_requests/{requestId} {
      allow read: if isAdmin()
        || (isDoctor() && resource.data.doctor_id == request.auth.uid);

      allow create: if isDoctor()
        && request.resource.data.doctor_id == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.old_schedule_id is string
        && doctorOwnsSchedule(request.resource.data.old_schedule_id)
        && request.resource.data.lock_id is string
        && request.resource.data.lock_id == (request.resource.data.doctor_id + '_' + request.resource.data.old_schedule_id)
        && existsAfter(/databases/$(database)/documents/schedule_change_request_locks/$(request.resource.data.lock_id))
        && scheduleChangeLockDocAfter(request.resource.data.lock_id).data.doctor_id == request.resource.data.doctor_id
        && scheduleChangeLockDocAfter(request.resource.data.lock_id).data.schedule_id == request.resource.data.old_schedule_id
        && scheduleChangeLockDocAfter(request.resource.data.lock_id).data.request_id == requestId
        && scheduleChangeLockDocAfter(request.resource.data.lock_id).data.status == 'pending'
        && request.resource.data.old_day is string
        && request.resource.data.old_start_time is string
        && request.resource.data.old_end_time is string
        && request.resource.data.new_day is string
        && request.resource.data.new_start_time is string
        && request.resource.data.new_end_time is string
        && request.resource.data.reason is string
        && request.resource.data.doctor_name is string
        && request.resource.data.doctor_phone is string
        && request.resource.data.admin_approver_id == null
        && request.resource.data.rejection_reason == null;

      allow update, delete: if isAdmin();
    }

    match /schedule_change_request_locks/{lockId} {
      allow read: if isAdmin()
        || (isDoctor() && (resource == null || resource.data.doctor_id == request.auth.uid));

      allow create: if isDoctor()
        && request.resource.data.doctor_id == request.auth.uid
        && request.resource.data.schedule_id is string
        && doctorOwnsSchedule(request.resource.data.schedule_id)
        && request.resource.data.request_id is string
        && request.resource.data.status == 'pending';

      allow update: if isAdmin();

      allow delete: if isAdmin()
        || (isDoctor()
          && resource.data.doctor_id == request.auth.uid
          && resource.data.status == 'pending');
    }

    match /doctor_schedule_mutation_locks/{lockId} {
      allow read: if isAdmin();

      allow create: if isAdmin()
        && lockId == 'global'
        && request.resource.data.lock_scope == 'global'
        && request.resource.data.status == 'pending'
        && request.resource.data.operation is string
        && request.resource.data.type is string
        && request.resource.data.doctor_id is string
        && request.resource.data.request_id is string;

      allow update, delete: if isAdmin()
        && lockId == 'global';
    }

    match /patient_queue_locks/{lockId} {
      allow read: if signedIn()
        && (
          isAdmin()
          || resource == null
          || resource.data.patient_id == request.auth.uid
          || resource.data.doctor_id == request.auth.uid);

      allow create: if isPatient()
        && request.resource.data.patient_id == request.auth.uid
        && request.resource.data.doctor_id is string
        && request.resource.data.schedule_id is string
        && request.resource.data.appointment_date is timestamp
        && request.resource.data.queue_id is string
        && request.resource.data.status == 'active'
        && queueMutationMatchesPatientLock(
          request.resource.data.queue_id,
          request.resource.data.patient_id,
          request.resource.data.doctor_id,
          request.resource.data.schedule_id
        )
        && queueDocAfter(request.resource.data.queue_id).data.status in ['menunggu', 'rescheduled']
        && queueDocAfter(request.resource.data.queue_id).data.queue_number > 0;

      allow update: if isPatient()
        && resource.data.patient_id == request.auth.uid
        && request.resource.data.patient_id == request.auth.uid
        && request.resource.data.doctor_id == resource.data.doctor_id
        && request.resource.data.queue_id == resource.data.queue_id
        && request.resource.data.schedule_id is string
        && request.resource.data.appointment_date is timestamp
        && request.resource.data.status == 'active'
        && queueMutationMatchesPatientLock(
          request.resource.data.queue_id,
          request.resource.data.patient_id,
          request.resource.data.doctor_id,
          request.resource.data.schedule_id
        )
        && queueDocAfter(request.resource.data.queue_id).data.status in ['menunggu', 'rescheduled']
        && queueDocAfter(request.resource.data.queue_id).data.queue_number > 0;

      allow delete: if (
        isPatient()
        && resource.data.patient_id == request.auth.uid
        && existsAfter(/databases/$(database)/documents/queues/$(resource.data.queue_id))
        && queueDocAfter(resource.data.queue_id).data.updated_at == request.time
        && queueDocAfter(resource.data.queue_id).data.patient_id == resource.data.patient_id
        && queueDocAfter(resource.data.queue_id).data.doctor_id == resource.data.doctor_id
        && queueDocAfter(resource.data.queue_id).data.schedule_id == resource.data.schedule_id
        && queueDocAfter(resource.data.queue_id).data.status in ['cancelled_by_patient', 'cancelled_by_doctor', 'selesai', 'completed']
      ) || (
        isDoctor()
        && resource.data.doctor_id == request.auth.uid
      );
    }

    match /queue_sequence_counters/{scheduleId} {
      allow read: if signedIn();

      allow create: if isPatient()
        && request.resource.data.schedule_id == scheduleId
        && request.resource.data.appointment_date is timestamp
        && request.resource.data.next_queue_number == 2
        && request.resource.data.status == 'active'
        && existsAfter(/databases/$(database)/documents/patient_queue_locks/$(patientQueueLockId(scheduleId)))
        && patientQueueLockDocAfter(patientQueueLockId(scheduleId)).data.patient_id == request.auth.uid
        && patientQueueLockDocAfter(patientQueueLockId(scheduleId)).data.doctor_id == scheduleDoc(scheduleId).data.doctor_id
        && patientQueueLockDocAfter(patientQueueLockId(scheduleId)).data.schedule_id == scheduleId
        && patientQueueLockDocAfter(patientQueueLockId(scheduleId)).data.status == 'active'
        && patientQueueLockDocAfter(patientQueueLockId(scheduleId)).data.updated_at == request.time
        && existsAfter(/databases/$(database)/documents/queues/$(patientQueueLockDocAfter(patientQueueLockId(scheduleId)).data.queue_id))
        && queueDocAfter(patientQueueLockDocAfter(patientQueueLockId(scheduleId)).data.queue_id).data.schedule_id == scheduleId
        && queueDocAfter(patientQueueLockDocAfter(patientQueueLockId(scheduleId)).data.queue_id).data.patient_id == request.auth.uid
        && queueDocAfter(patientQueueLockDocAfter(patientQueueLockId(scheduleId)).data.queue_id).data.queue_number == 1
        && queueDocAfter(patientQueueLockDocAfter(patientQueueLockId(scheduleId)).data.queue_id).data.status == 'menunggu'
        && queueDocAfter(patientQueueLockDocAfter(patientQueueLockId(scheduleId)).data.queue_id).data.updated_at == request.time;

      allow update: if isPatient()
        && request.resource.data.schedule_id == scheduleId
        && request.resource.data.appointment_date is timestamp
        && request.resource.data.next_queue_number is int
        && request.resource.data.status == 'active'
        && existsAfter(/databases/$(database)/documents/patient_queue_locks/$(patientQueueLockId(scheduleId)))
        && patientQueueLockDocAfter(patientQueueLockId(scheduleId)).data.patient_id == request.auth.uid
        && patientQueueLockDocAfter(patientQueueLockId(scheduleId)).data.doctor_id == scheduleDoc(scheduleId).data.doctor_id
        && patientQueueLockDocAfter(patientQueueLockId(scheduleId)).data.updated_at == request.time
        && (
          (
            request.resource.data.appointment_date == resource.data.appointment_date
            && request.resource.data.next_queue_number == resource.data.next_queue_number + 1
            && queueDocAfter(patientQueueLockDocAfter(patientQueueLockId(scheduleId)).data.queue_id).data.queue_number == resource.data.next_queue_number
            && queueDocAfter(patientQueueLockDocAfter(patientQueueLockId(scheduleId)).data.queue_id).data.status in ['menunggu', 'rescheduled']
            && queueDocAfter(patientQueueLockDocAfter(patientQueueLockId(scheduleId)).data.queue_id).data.updated_at == request.time
          )
          || (
            request.resource.data.appointment_date != resource.data.appointment_date
            && request.resource.data.next_queue_number == 2
            && existsAfter(/databases/$(database)/documents/queues/$(patientQueueLockDocAfter(patientQueueLockId(scheduleId)).data.queue_id))
            && queueDocAfter(patientQueueLockDocAfter(patientQueueLockId(scheduleId)).data.queue_id).data.schedule_id == scheduleId
            && queueDocAfter(patientQueueLockDocAfter(patientQueueLockId(scheduleId)).data.queue_id).data.patient_id == request.auth.uid
            && queueDocAfter(patientQueueLockDocAfter(patientQueueLockId(scheduleId)).data.queue_id).data.queue_number == 1
            && queueDocAfter(patientQueueLockDocAfter(patientQueueLockId(scheduleId)).data.queue_id).data.status == 'menunggu'
            && queueDocAfter(patientQueueLockDocAfter(patientQueueLockId(scheduleId)).data.queue_id).data.updated_at == request.time
          )
        );

      allow delete: if isAdmin();
    }

    match /doctor_notifications/{notificationId} {
      allow read: if isAdmin()
        || (isDoctor() && resource.data.doctor_id == request.auth.uid);

      allow create: if isAdmin()
        && request.resource.data.doctor_id is string
        && request.resource.data.title is string
        && request.resource.data.body is string
        && request.resource.data.type is string
        && request.resource.data.request_id is string
        && request.resource.data.is_read == false;

      allow update: if isAdmin()
        || (isDoctor()
          && resource.data.doctor_id == request.auth.uid
          && doctorNotificationReadOnlyUpdate());

      allow delete: if isAdmin();
    }

    match /doctor_absences/{absenceId} {
      allow read: if isAdmin()
        || (isDoctor() && resource.data.doctor_id == request.auth.uid);

      allow create: if isDoctor()
        && request.resource.data.doctor_id == request.auth.uid
        && request.resource.data.doctor_name is string
        && request.resource.data.date is timestamp
        && request.resource.data.status == 'reported';

      allow update, delete: if isAdmin();
    }

    match /patient_notifications/{notificationId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.patient_id == request.auth.uid);

      allow create: if isDoctor()
        && request.resource.data.doctor_id == request.auth.uid
        && request.resource.data.patient_id is string
        && request.resource.data.queue_id is string
        && request.resource.data.doctor_name is string
        && request.resource.data.schedule_id is string
        && request.resource.data.title is string
        && request.resource.data.message is string
        && request.resource.data.reason is string
        && request.resource.data.is_read == false
        && queueBelongsToDoctorAndPatient(request.resource.data.queue_id);

      allow update: if isAdmin()
        || (signedIn()
          && resource.data.patient_id == request.auth.uid
          && patientNotificationReadOnlyUpdate());

      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read, write: if isAdmin();
    }

    match /deleted_accounts/{accountId} {
      allow read, write: if isAdmin();
    }

    match /activities/{activityId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
